def update_status(text):
    status_label.configure(text=text)
    app.update_idletasks()

def start_bypass():
    btn7.configure(state="disabled")
    progress.start()
    update_status("Starting bypass sequence...")

    def run_sequence():
        try:
            adapter_name, _ = NetworkManager.get_real_adapter()

            if check4_var.get() == "on":
                update_status("Clearing Roblox cookies...")
                clear_browser_cookies()

            if check3_var.get() == "on":
                if not adapter_name:
                    messagebox.showerror("Error", "No valid network adapter found!")
                    return
                update_status("Generating new MAC address...")
                new_mac = NetworkManager.generate_mac()
                update_status(f"Applying new MAC: {new_mac}")
                success = NetworkManager.set_registry_mac(adapter_name, new_mac)
                if success:
                    update_status("Restarting network adapter...")
                    NetworkManager.restart_adapter(adapter_name)
                    time.sleep(4)

            if check6_var.get() == "on":
                update_status("Purging old Roblox data...")
                app_path = Path(os.environ.get('LOCALAPPDATA')) / 'Roblox'
                if app_path.exists():
                    shutil.rmtree(app_path, ignore_errors=True)

                update_status("Downloading fresh Roblox installer...")
                installer_url = "https://www.roblox.com/download/client"
                temp_path = Path(os.environ['TEMP']) / 'RobloxPlayerInstaller.exe'

                def progress_hook(block_num, block_size, total_size):
                    if total_size > 0:
                        pct = min(int(block_num * block_size * 100 / total_size), 100)
                        update_status(f"Downloading Roblox... {pct}%")

                urllib.request.urlretrieve(installer_url, str(temp_path), reporthook=progress_hook)

                update_status("Running Roblox installer...")
                subprocess.run([str(temp_path)], shell=True)

                try:
                    os.remove(temp_path)
                except Exception:
                    pass

            if check5_var.get() == "on":
                update_status("Restarting PC in 10 seconds...")
                time.sleep(10)
                subprocess.run("shutdown /r /t 0", shell=True)
                return

            update_status("Bypass Completed Successfully!")
            messagebox.showinfo("Success", "Roblox Ban Async Bypass Finished!")

        except Exception as e:
            messagebox.showerror("Error", f"An error occurred:\n{str(e)}")
            update_status("Error occurred!")
        finally:
            btn7.configure(state="normal")
            progress.stop()
            progress.set(0)

    threading.Thread(target=run_sequence, daemon=True).start()


btn7 = ctk.CTkButton(content, text="Start Bypass", font=("Segoe UI", 13, "bold"), height=38, width=190,
